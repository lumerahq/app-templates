{
  "name": "{{projectName}}",
  "private": true,
  "type": "module",
  "pnpm": {
    "overrides": {
      "@tanstack/router-core": "1.155.0"
    }
  },
  "lumera": {
    "version": 1,
    "name": "{{projectTitle}}"
  },
  "scripts": {
    "dev": "pnpm dlx @lumerahq/cli dev",
    "deploy": "pnpm dlx @lumerahq/cli apply app",
    "dev:vite": "vite",
    "build": "vite build && tsc",
    "preview": "vite preview",
    "typecheck": "tsr generate && tsc --noEmit",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome check . && tsr generate && tsc --noEmit"
  },
  "dependencies": {
    "@lumerahq/ui": "^0.6.0",
    "@tanstack/react-query": "^5.90.11",
    "@tanstack/react-router": "1.155.0",
    "@tanstack/router-plugin": "1.155.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-cli": "1.155.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
