{
  "id": "ca_customers",
  "name": "ca_customers",
  "fields": [
    { "name": "name", "type": "text", "required": true },
    { "name": "email", "type": "text" },
    { "name": "phone", "type": "text" },
    { "name": "contact_name", "type": "text" },
    {
      "name": "status",
      "type": "select",
      "values": ["active", "contacted", "promised", "escalated", "resolved"],
      "default": "active"
    },
    { "name": "total_outstanding", "type": "number" },
    { "name": "total_paid", "type": "number" },
    { "name": "risk_score", "type": "number" },
    {
      "name": "risk_level",
      "type": "select",
      "values": ["low", "medium", "high"]
    },
    { "name": "payment_terms", "type": "text" },
    { "name": "next_action", "type": "text" },
    { "name": "next_follow_up", "type": "date" },
    { "name": "last_contact_date", "type": "date" },
    { "name": "notes", "type": "text" }
  ],
  "indexes": [
    { "fields": ["status"] },
    { "fields": ["risk_score"] },
    { "fields": ["name"] }
  ]
}
