{
  "id": "ar_invoices",
  "name": "ar_invoices",
  "fields": [
    { "name": "customer", "type": "relation", "collection": "customers", "required": true },
    { "name": "invoice_number", "type": "text", "required": true },
    { "name": "amount", "type": "number", "required": true },
    { "name": "due_date", "type": "date", "required": true },
    { "name": "days_overdue", "type": "number" },
    {
      "name": "status",
      "type": "select",
      "values": ["open", "partial", "paid", "written_off"],
      "default": "open"
    }
  ],
  "indexes": [
    { "fields": ["customer"] },
    { "fields": ["status"] }
  ]
}
