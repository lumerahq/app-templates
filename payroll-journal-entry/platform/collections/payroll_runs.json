    { "name": "total_debits", "type": "number" },
    { "name": "total_credits", "type": "number" },
    { "name": "notes", "type": "text" },
    { "name": "extracted_data", "type": "json" }
  ],
  "indexes": [
    { "fields": ["status"] }
  ]
}
