{
  "id": "payroll_runs",
  "name": "payroll_runs",
  "fields": [
    { "name": "pay_period_start", "type": "date" },
    { "name": "pay_period_end", "type": "date" },
    { "name": "pay_date", "type": "date" },
    { "name": "document", "type": "lumera_file" },
    {
      "name": "status",
