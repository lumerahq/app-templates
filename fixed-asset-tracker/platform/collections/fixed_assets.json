{
  "id": "fixed_assets",
  "name": "fixed_assets",
  "fields": [
    {
      "name": "name",
      "type": "text",
      "required": true
    },
    {
      "name": "asset_tag",
      "type": "text"
    },
    {
      "name": "category",
      "type": "select",
      "values": ["equipment", "furniture", "vehicles", "software", "buildings", "leasehold_improvements"],
      "required": true
    },
    {
      "name": "status",
      "type": "select",
      "values": ["active", "fully_depreciated", "disposed"],
      "default": "active"
    },
    {
      "name": "acquisition_date",
      "type": "date",
      "required": true
    },
    {
      "name": "cost_basis",
      "type": "number",
      "required": true
    },
    {
      "name": "salvage_value",
      "type": "number"
    },
    {
      "name": "useful_life_months",
      "type": "number",
      "required": true
    },
    {
      "name": "depreciation_method",
      "type": "select",
      "values": ["straight_line", "declining_balance"],
      "default": "straight_line"
    },
    {
      "name": "accumulated_depreciation",
      "type": "number"
    },
    {
      "name": "location",
      "type": "text"
    },
    {
      "name": "department",
      "type": "text"
    },
    {
      "name": "disposal_date",
      "type": "date"
    },
    {
      "name": "disposal_proceeds",
      "type": "number"
    },
    {
      "name": "notes",
      "type": "text"
    }
  ],
  "indexes": [
    { "fields": ["status"] },
    { "fields": ["category"] }
  ]
}
