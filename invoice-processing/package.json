{
  "name": "my-lumera-app",
  "private": true,
  "type": "module",
  "pnpm": {
    "overrides": {
      "@tanstack/router-core": "1.155.0"
    }
  },
  "lumera": {
    "version": 1,
    "name": "My Lumera App"
  },
  "scripts": {
    "dev": "pnpm dlx @lumerahq/cli dev",
    "deploy": "pnpm dlx @lumerahq/cli apply app",
    "dev:vite": "vite",
    "build": "vite build && tsc",
    "preview": "vite preview",
    "typecheck": "tsr generate && tsc --noEmit",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome check . && tsr generate && tsc --noEmit"
  },
  "dependencies": {
    "@cyntler/react-doc-viewer": "^1.17.1",
    "@lumerahq/ui": "^0.5.0",
    "@tanstack/react-query": "^5.90.11",
    "@tanstack/react-router": "1.155.0",
    "@tanstack/router-plugin": "1.155.0",
    "lucide-react": "^0.469.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/router-cli": "1.155.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.7.2",
    "vite": "^7.1.7"
  }
}
