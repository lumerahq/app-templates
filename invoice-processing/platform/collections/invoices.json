{
  "id": "invoices",
  "name": "invoices",
  "fields": [
    { "name": "vendor_name", "type": "text" },
    { "name": "invoice_number", "type": "text" },
    { "name": "invoice_date", "type": "date" },
    { "name": "due_date", "type": "date" },
    { "name": "total_amount", "type": "number" },
    { "name": "currency", "type": "text" },
    { "name": "description", "type": "text" },
    {
      "name": "status",
      "type": "select",
      "values": ["draft", "processing", "review", "approved", "rejected"],
      "default": "draft"
    },
    { "name": "document", "type": "lumera_file" },
    { "name": "extracted_data", "type": "json" },
    { "name": "notes", "type": "text" }
  ],
  "indexes": [
    { "fields": ["status"] },
    { "fields": ["vendor_name"] }
  ]
}
